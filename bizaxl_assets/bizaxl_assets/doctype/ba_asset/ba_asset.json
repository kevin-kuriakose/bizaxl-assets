{
    "name": "BA Asset",
    "doctype": "DocType",
    "module": "BizAxl Assets",
    "autoname": "naming_series:",
    "naming_series": "AST-.YYYY.-",
    "title_field": "asset_name",
    "search_fields": "asset_name,asset_category,status",
    "is_submittable": 1,
    "fields": [
        {"fieldname": "naming_series", "fieldtype": "Select", "options": "AST-.YYYY.-"},
        {"fieldname": "asset_name", "fieldtype": "Data", "label": "Asset Name", "reqd": 1, "in_list_view": 1},
        {"fieldname": "asset_category", "fieldtype": "Link", "label": "Asset Category", "options": "BA Asset Category", "reqd": 1, "in_list_view": 1},
        {"fieldname": "status", "fieldtype": "Select", "label": "Status",
         "options": "Draft\nSubmitted\nIn Location\nIssued\nScrapped\nSold",
         "default": "Draft", "in_list_view": 1},
        {"fieldname": "col1", "fieldtype": "Column Break"},
        {"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "BA Company", "reqd": 1},
        {"fieldname": "location", "fieldtype": "Data", "label": "Location"},
        {"fieldname": "custodian", "fieldtype": "Link", "label": "Custodian", "options": "User"},
        {"fieldname": "sec_purchase", "fieldtype": "Section Break", "label": "Purchase Details"},
        {"fieldname": "purchase_date", "fieldtype": "Date", "label": "Purchase Date", "reqd": 1, "in_list_view": 1},
        {"fieldname": "gross_purchase_amount", "fieldtype": "Currency", "label": "Gross Purchase Amount", "reqd": 1},
        {"fieldname": "purchase_invoice", "fieldtype": "Link", "label": "Purchase Invoice", "options": "BA Purchase Invoice"},
        {"fieldname": "supplier", "fieldtype": "Link", "label": "Supplier", "options": "BA Supplier"},
        {"fieldname": "sec_dep", "fieldtype": "Section Break", "label": "Depreciation"},
        {"fieldname": "calculate_depreciation", "fieldtype": "Check", "label": "Calculate Depreciation", "default": "1"},
        {"fieldname": "depreciation_method", "fieldtype": "Select", "label": "Method",
         "options": "Straight Line\nDouble Declining Balance\nWritten Down Value"},
        {"fieldname": "total_number_of_depreciations", "fieldtype": "Int", "label": "Total Depreciations"},
        {"fieldname": "frequency_of_depreciation", "fieldtype": "Select", "label": "Frequency",
         "options": "Monthly\nQuarterly\nYearly"},
        {"fieldname": "depreciation_start_date", "fieldtype": "Date", "label": "Depreciation Start"},
        {"fieldname": "col2", "fieldtype": "Column Break"},
        {"fieldname": "salvage_value", "fieldtype": "Currency", "label": "Salvage Value", "default": "0"},
        {"fieldname": "value_after_depreciation", "fieldtype": "Currency", "label": "Current Value", "read_only": 1},
        {"fieldname": "accumulated_depreciation", "fieldtype": "Currency", "label": "Accumulated Depreciation", "read_only": 1},
        {"fieldname": "schedules", "fieldtype": "Table", "label": "Depreciation Schedule",
         "options": "BA Asset Depreciation Schedule"},
        {"fieldname": "sec_disposal", "fieldtype": "Section Break", "label": "Disposal"},
        {"fieldname": "disposal_date", "fieldtype": "Date", "label": "Disposal Date"},
        {"fieldname": "disposal_amount", "fieldtype": "Currency", "label": "Disposal Amount"}
    ],
    "permissions": [
        {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1},
        {"role": "Accounts Manager", "read": 1, "write": 1, "create": 1, "submit": 1},
        {"role": "Accounts User", "read": 1}
    ]
}
