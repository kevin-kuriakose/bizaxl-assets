{
    "name": "BA Asset Repair",
    "doctype": "DocType",
    "module": "BizAxl Assets",
    "autoname": "naming_series:",
    "naming_series": "AR-.YYYY.-",
    "is_submittable": 1,
    "fields": [
        {"fieldname": "naming_series", "fieldtype": "Select", "options": "AR-.YYYY.-"},
        {"fieldname": "asset", "fieldtype": "Link", "label": "Asset", "options": "BA Asset", "reqd": 1, "in_list_view": 1},
        {"fieldname": "failure_date", "fieldtype": "Date", "label": "Failure Date", "reqd": 1, "in_list_view": 1},
        {"fieldname": "repair_status", "fieldtype": "Select", "label": "Status",
         "options": "Pending\nIn Progress\nCompleted\nCancelled",
         "default": "Pending", "in_list_view": 1},
        {"fieldname": "col1", "fieldtype": "Column Break"},
        {"fieldname": "assign_to", "fieldtype": "Link", "label": "Assigned To", "options": "User"},
        {"fieldname": "completion_date", "fieldtype": "Date", "label": "Completion Date"},
        {"fieldname": "repair_cost", "fieldtype": "Currency", "label": "Repair Cost", "in_list_view": 1},
        {"fieldname": "capitalize_repair_cost", "fieldtype": "Check", "label": "Capitalize Repair Cost"},
        {"fieldname": "description", "fieldtype": "Text", "label": "Problem Description"},
        {"fieldname": "resolution", "fieldtype": "Text", "label": "Resolution"}
    ],
    "permissions": [
        {"role": "System Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1},
        {"role": "Accounts Manager", "read": 1, "write": 1, "create": 1, "submit": 1},
        {"role": "Accounts User", "read": 1, "write": 1, "create": 1}
    ]
}
